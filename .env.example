# ============================================
# Faceless YouTube Automation Agent - Config
# ============================================

# Google Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 Key (required)
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Channel ID (required)
YOUTUBE_CHANNEL_ID=your_channel_id_here

# OAuth2 Client Credentials (required for uploading)
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Replicate Video Generation API (optional, alternative to Veo)
REPLICATE_API_TOKEN=your_replicate_api_token_here
# VIDEO_GENERATION_PROVIDER=replicate
REPLICATE_VIDEO_MODEL=prunaai/p-video
REPLICATE_VIDEO_RESOLUTION=720p
REPLICATE_VIDEO_FPS=24
REPLICATE_VIDEO_DRAFT=false
REPLICATE_POLL_INTERVAL=5
REPLICATE_TIMEOUT_SECONDS=420

# Google Veo 3.1 Video Generation (default, uses GEMINI_API_KEY)
VIDEO_GENERATION_PROVIDER=veo
VEO_MODEL=veo-3.1-generate-preview
VEO_PERSON_GENERATION=allow_all
VEO_POLL_INTERVAL=10
VEO_TIMEOUT_SECONDS=600

# Content Settings
CHANNEL_NICHE=kids_cartoon
TARGET_AUDIENCE=children
DEFAULT_LANGUAGE=en

# Video Settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
SHORT_WIDTH=1080
SHORT_HEIGHT=1920
VIDEO_FPS=24
VIDEO_DURATION_MIN=180
VIDEO_DURATION_MAX=600

# TTS Voice (edge-tts voices)
TTS_VOICE=en-US-AnaNeural

# Schedule Settings (24h format)
UPLOAD_TIME=10:00
UPLOAD_TIMEZONE=Asia/Kolkata

# Output Directories
OUTPUT_DIR=output
SCRIPTS_DIR=output/scripts
VIDEOS_DIR=output/videos
AUDIO_DIR=output/audio
THUMBNAILS_DIR=output/thumbnails
ASSETS_DIR=assets
